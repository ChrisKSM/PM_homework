From e30631ef32b1e38be01c80879a1370b6c564ace0 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?=EB=82=A8=ED=83=9C=ED=97=8C?= <taehun.nam@lge.com>
Date: Mon, 10 Nov 2025 04:29:32 +0000
Subject: [PATCH] add injection scripts

---
 Dockerfile             | 11 ++++++++---
 public/index.html      |  2 ++
 settings/entrypoint.sh | 26 ++++++++++++++++++++++++++
 3 files changed, 36 insertions(+), 3 deletions(-)
 create mode 100644 settings/entrypoint.sh

diff --git a/Dockerfile b/Dockerfile
index 0946740..b7b9c59 100644
--- a/Dockerfile
+++ b/Dockerfile
@@ -9,7 +9,8 @@ RUN npm config set registry https://nexus.hedej.lge.com/repository/npm-group/ --
 RUN npm install -f
 
 ARG BUILD_ARGS
-RUN echo ${BUILD_ARGS} | base64 -d > .env
+RUN echo ${BUILD_ARGS} | base64 -d > .env || echo "skip env"
+
 RUN cat .env
 # 소스를 작업폴더로 복사하고 빌드
 COPY . /usr/src/app
@@ -23,6 +24,10 @@ FROM nginx:1.18-alpine
 COPY --from=builder /usr/src/app/build /usr/share/nginx/html
 COPY --from=builder /usr/src/app/settings/default.conf /etc/nginx/conf.d/default.conf
 
-# 3000포트 오픈하고 nginx 실행
+# entrypoint 스크립트 복사 및 실행 권한 부여
+COPY --from=builder /usr/src/app/settings/entrypoint.sh /entrypoint.sh
+RUN chmod +x /entrypoint.sh
+
+# 3000포트 오픈하고 entrypoint 스크립트 실행
 EXPOSE 3000
-CMD ["nginx", "-g", "daemon off;"]
+ENTRYPOINT ["/entrypoint.sh"]
diff --git a/public/index.html b/public/index.html
index aa069f2..adb084d 100644
--- a/public/index.html
+++ b/public/index.html
@@ -3,6 +3,8 @@
   <head>
     <meta charset="utf-8" />
     <link rel="icon" href="%PUBLIC_URL%/favicon.ico" />
+
+    <script src="%PUBLIC_URL%/workspace_env.js"></script>
     <meta name="viewport" content="width=device-width, initial-scale=1" />
     <meta name="theme-color" content="#000000" />
     <meta
diff --git a/settings/entrypoint.sh b/settings/entrypoint.sh
new file mode 100644
index 0000000..390d2bc
--- /dev/null
+++ b/settings/entrypoint.sh
@@ -0,0 +1,26 @@
+#!/bin/sh
+
+echo "=== Generating env.js from environment variables ==="
+
+# 환경변수를 env.js 파일로 생성
+cat > /usr/share/nginx/html/workspace_env.js << 'EOF'
+window.workspace_env = {
+EOF
+
+# 환경변수 중에서 프론트엔드에서 사용할 것들만 필터링하여 추가
+printenv | grep -E '^(REACT_APP_|VITE_|API_|NODE_ENV|PUBLIC_)' | sort | while IFS='=' read -r key value; do
+  # 값에 있는 특수문자들을 이스케이프 처리
+  escaped_value=$(echo "$value" | sed 's/\\/\\\\/g' | sed 's/"/\\"/g' | sed "s/'/\\'/g")
+  echo "  $key: \"$escaped_value\"," >> /usr/share/nginx/html/workspace_env.js
+done
+
+cat >> /usr/share/nginx/html/workspace_env.js << 'EOF'
+};
+EOF
+
+echo "Generated workspace_env.js file:"
+cat /usr/share/nginx/html/workspace_env.js
+echo "=================================="
+
+# nginx 시작
+exec nginx -g "daemon off;"
\ No newline at end of file
